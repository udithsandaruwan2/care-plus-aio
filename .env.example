# ── Care Plus environment (copy to .env; never commit .env) ──────────────

# Django
DJANGO_SETTINGS_MODULE=careplus.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (TimescaleDB image bundles PostGIS + TimescaleDB)
POSTGRES_DB=careplus
POSTGRES_USER=careplus
POSTGRES_PASSWORD=careplus
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Host-side port for reaching the DB from your machine (avoids clashing with a
# local Postgres already on 5432). Internal container port stays 5432.
POSTGRES_HOST_PORT=5433

# Redis (cache + Redlock + Celery broker + Channels layer)
REDIS_URL=redis://redis:6379/0

# Google Gemini (optional NLP / chat — NOT default ASR)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# stub | gemini | local  (local uses LOCAL_LLM_URL when you add one)
VOICE_INTENT_BACKEND=
# faster_whisper (default) | gemini_audio | client | auto
ASR_BACKEND=faster_whisper
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_DOWNLOAD_ROOT=/ml/whisper
WHISPER_SINHALA_MODEL=SPEAK-ASR/faster-whisper-medium-si-exp10-fp16
WHISPER_SINHALA_COMPUTE_TYPE=int8
WHISPER_PRELOAD=false
# auto (piper→gemini→browser) | piper | gemini_tts | browser
TTS_BACKEND=auto
TTS_GEMINI_MODEL=gemini-2.5-flash-preview-tts
TTS_GEMINI_VOICE=Kore
# Neural Sinhala/Tamil when Gemini TTS quota is hit (edge-tts, no extra API key).
EDGE_TTS_ENABLED=true
PIPER_BIN=
PIPER_MODEL_DIR=/ml/tts/piper
PIPER_EN_MODEL=en_US-lessac-medium.onnx
# stub | gemini — chat copy only. MATCH/REFINE always local VEHMF (never Gemini ranks).
DIALOGUE_CHAT_BACKEND=
# Max Gemini chat turns per user per window (0 = disable Gemini chat).
DIALOGUE_GEMINI_RATE_LIMIT=30
DIALOGUE_GEMINI_RATE_WINDOW_SEC=3600
LOCAL_LLM_URL=

# Firebase Cloud Messaging (push)
FCM_CREDENTIALS_JSON=

# ML / matching (Step 17–18)
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=intfloat/multilingual-e5-base
FAISS_ARTIFACT_DIR=/ml/artifacts
AHP_WEIGHTS_PATH=/config/ahp_weights.json
# Blend trained ALS CF into VEHMF (Step 22). false → zero β, CBF/geo/trust only.
CF_ENABLED=true
# Minimum patient profile % before requesting care (Step 22b).
PATIENT_PROFILE_MIN_COMPLETION=80
# Caregiver onboarding + auto-approval (Step 22c).
CAREGIVER_AUTO_APPROVE=true
CAREGIVER_PROFILE_MIN_COMPLETION=80
# Pending care requests auto-expire after this many hours (Step 23).
CARE_REQUEST_TTL_HOURS=72
ONE_PRIMARY_CAREGIVER=true
CARE_REQUEST_NOTIFY_EMAIL_ENABLED=true
LEAD_ACK_EMAIL_ENABLED=true
DEFAULT_FROM_EMAIL=noreply@careplus.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Step 31 — payments (mock | payhere). Mock confirm is explicit; PayHere needs webhook sig.
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_CONFIRM_ENABLED=true
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
PAYHERE_NOTIFY_URL=
FRONTEND_BASE_URL=http://localhost:5173
NOTIFICATION_EMAIL_ENABLED=true
# Step 40 — templated notification emails (Celery worker sends in staging)
RECEIPT_EMAIL_ENABLED=true
# Step 34 — Fernet key for medical record field encryption (leave blank for dev derived key)
FIELD_ENCRYPTION_KEY=
# Step 35 — medical record attachments
MEDICAL_RECORD_MAX_UPLOAD_BYTES=10485760
MEDICAL_RECORD_DOWNLOAD_URL_TTL_SECONDS=3600
# Optional comma overrides (α,β,γ,δ) — leave blank to use JSON / AHP solve:
# AHP_WEIGHTS=0.45,0.10,0.20,0.25
# AHP_EMERGENCY_WEIGHTS=0.80,0.05,0.05,0.10

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws
